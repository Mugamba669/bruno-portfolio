# MongoDB connection string. NOTE: percent-encode special chars in the password
# (e.g. '@' -> '%40').
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/bruno-portifolio
# Password for the single admin at /admin/login
ADMIN_PASSWORD=set-a-strong-password
# Secret used to sign the admin session cookie (>=32 chars; openssl rand -base64 48)
SESSION_SECRET=generate-a-long-random-secret
